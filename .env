# ============================================
# ModuLearn Environment Configuration
# ============================================
# Copy this file to .env in the ModuLearn root directory

# ----------------
# Environment Mode
# ----------------
# Set to 'true' for development, 'false' for production
DEBUG=true

# ----------------
# Email Configuration
# ----------------
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=true
EMAIL_HOST_USER=your-email@example.com
EMAIL_HOST_PASSWORD=your-email-password

# ----------------
# LTI Tool Credentials
# ----------------

# CodeCheck
CODECHECK_KEY=your_codecheck_key
CODECHECK_SECRET=your_codecheck_secret
CODECHECK_LAUNCH=https://codecheck.example.com/launch

# CodeLab
CODELAB_KEY=your_codelab_key
CODELAB_SECRET=your_codelab_secret
CODELAB_LAUNCH=https://codelab.example.com/launch

# CodeOcean
CODEOCEAN_KEY=your_codeocean_key
CODEOCEAN_SECRET=your_codeocean_secret
CODEOCEAN_LAUNCH=https://codeocean.example.com/launch

# CodeWorkout
CODEWORKOUT_KEY=your_codeworkout_key
CODEWORKOUT_SECRET=your_codeworkout_secret
CODEWORKOUT_LAUNCH=https://codeworkout.example.com/launch

# CTAT (Cognitive Tutor Authoring Tools)
CTAT_KEY=your_ctat_key
CTAT_SECRET=your_ctat_secret
CTAT_LAUNCH=https://ctat.example.com/launch

# DBQA (Database Question & Answer)
DBQA_KEY=your_dbqa_key
DBQA_SECRET=your_dbqa_secret
DBQA_LAUNCH=https://dbqa.example.com/launch

# OpenDSA Problems
OPENDSA_PROBLEMS_KEY=your_opendsa_problems_key
OPENDSA_PROBLEMS_SECRET=your_opendsa_problems_secret
OPENDSA_PROBLEMS_LAUNCH=https://opendsa.example.com/problems/launch

# OpenDSA Slideshows
OPENDSA_SLIDESHOWS_KEY=your_opendsa_slideshows_key
OPENDSA_SLIDESHOWS_SECRET=your_opendsa_slideshows_secret
OPENDSA_SLIDESHOWS_LAUNCH=https://opendsa.example.com/slideshows/launch

# =============================================================================
# PAWS MySQL Database Configuration
# =============================================================================
# Database Connection (as seen from SSH server if using tunnel)
PAWS_DB_HOST=127.0.0.1
PAWS_DB_PORT=3306
PAWS_DB_USER=qkw3
PAWS_DB_PASSWORD=6Pqt5KZm5v2n

# Schema Names (optional - defaults shown)
PAWS_DB_KT_SCHEMA=portal_test2
PAWS_DB_AGGREGATE_SCHEMA=aggregate

# SSH Tunnel Configuration (for development)
PAWS_DB_USE_SSH=True
PAWS_DB_SSH_HOST=pawscomp2.sis.pitt.edu
PAWS_DB_SSH_PORT=22
PAWS_DB_SSH_USER=qkw3
PAWS_DB_SSH_PASSWORD=6Pqt5KZm5v2n

# =============================================================================
# KnowledgeTree Authentication Configuration
# =============================================================================
KT_AUTH_ENABLED=True
KT_AUTH_METHOD=api
KT_AUTH_FALLBACK=True
KT_API_URL=http://adapt2.sis.pitt.edu
KT_API_TIMEOUT=10
KT_SECURITY_CHECK_PATH=/kt/content/j_security_check